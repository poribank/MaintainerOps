# Development example. Replace every secret-like value before any real pilot,
# and keep local `.env*` files out of git.
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_PRIVATE_KEY=
# Use `dev-secret` only for local fixture replay. Use a long random value for live webhooks.
GITHUB_WEBHOOK_SECRET=dev-secret
GITHUB_AUTH_TOKEN=
WEBHOOK_PROXY_URL=
GITHUB_WRITES_ENABLED=false
GITHUB_API_VERSION=2026-03-10
STORE_DRIVER=memory
DATABASE_URL=postgres://maintainerops:maintainerops@localhost:5432/maintainerops
QUEUE_DRIVER=memory
QUEUE_INLINE_WORKER=true
REDIS_URL=redis://localhost:6379
AI_PROVIDER=disabled
AI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=chat-latest
AI_MAX_INPUT_CHARS=12000
WEB_ORIGIN=http://localhost:5173
SCORECARD_COMMAND=scorecard
OSV_SCANNER_COMMAND=osv-scanner
SCANNER_WORKSPACE_ROOT=
SCANNER_TIMEOUT_MS=120000
